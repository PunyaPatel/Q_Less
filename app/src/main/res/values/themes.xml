<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Qless" parent="Theme.Material3.Light.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/dividerColor</item>
        <item name="colorOnPrimaryContainer">@color/colorPrimary</item>
        
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/textColorPrimary</item>
        <item name="android:textColorSecondary">@color/textColorSecondary</item>
        
        <!-- Surface Colors -->
        <item name="colorSurface">@color/cardBackground</item>
        <item name="colorOnSurface">@color/textColorPrimary</item>
    </style>

    <style name="Theme.Qless" parent="Base.Theme.Qless" />
</resources>